#include <Keypad.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>
#include <ESP32Servo.h>  // For servo control

// ---------- TFT PIN CONFIGURATION ----------
#define TFT_CS   5
#define TFT_DC   16
#define TFT_RST  17
#define TFT_BL   4

Adafruit_ST7735 tft = Adafruit_ST7735(TFT_CS, TFT_DC, TFT_RST);

// ---------- Keypad configuration ----------
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1', '2', '3', 'A'},
  {'4', '5', '6', 'B'},
  {'7', '8', '9', 'C'},
  {'*', '0', '#', 'D'}
};

// ESP32 GPIOs connected to keypad
byte rowPins[ROWS] = {33, 25, 26, 27}; // R1, R2, R3, R4
byte colPins[COLS] = {14, 12, 13, 32}; // C1, C2, C3, C4

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------- Servo configuration ----------
Servo myServo;
#define SERVO_PIN 15   // PWM capable pin
int angle = 0;

// ---------- Variables ----------
String input = "";
const int MAX_INPUT_LEN = 16;

void setup() {
  Serial.begin(115200);
  Serial.println("TFT + Keypad + Servo Integration");

  // TFT setup
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);

  pinMode(TFT_BL, OUTPUT);
  digitalWrite(TFT_BL, HIGH);

  // TFT Header
  tft.setTextSize(2);
  tft.setTextColor(ST77XX_CYAN);
  tft.setCursor(0, 0);
  tft.println("Keypad Input:");
  tft.drawFastHLine(0, 28, tft.width(), ST77XX_WHITE);

  // Servo setup
  myServo.attach(SERVO_PIN);
  myServo.write(0);
  Serial.println("Servo initialized at 0°");

  // Input area
  tft.setTextSize(3);
  tft.setTextColor(ST77XX_YELLOW);
  tft.setCursor(0, 40);
  tft.print("Ready");
}

void loop() {
  char key = keypad.getKey();

  if (key) {
    Serial.print("Key Pressed: ");
    Serial.println(key);

    // Update input buffer
    if (input.length() < MAX_INPUT_LEN) {
      input += key;
    } else {
      input.remove(0, 1);
      input += key;
    }

    // Clear input area on TFT
    tft.fillRect(0, 40, tft.width(), 80, ST77XX_BLACK);
    tft.setCursor(0, 40);
    tft.print(input);

    // If key is between '0' and '9', move servo
    if (key >= '0' && key <= '9') {
      int num = key - '0';      // Convert char to integer
      angle = num * 30;         // Map 0–9 → 0°, 30°, 60°, … 270°, 300°
      myServo.write(angle);     // Move servo

      // Display servo angle on TFT
      tft.setTextSize(2);
      tft.setTextColor(ST77XX_GREEN);
      tft.setCursor(0, 90);
      tft.fillRect(0, 90, tft.width(), 40, ST77XX_BLACK); // Clear previous angle
      tft.print("Angle: ");
      tft.print(angle);
      tft.println(" deg");

      Serial.print("Servo Moved to ");
      Serial.print(angle);
      Serial.println(" degrees");
    }
  }
}
