#include <Keypad.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>
#include <Adafruit_Fingerprint.h>
#include <HardwareSerial.h>
#include <ESP32Servo.h>

// ---------- TFT PIN CONFIGURATION ----------
#define TFT_CS   5
#define TFT_DC   16
#define TFT_RST  17
#define TFT_BL   4

Adafruit_ST7735 tft = Adafruit_ST7735(TFT_CS, TFT_DC, TFT_RST);

// ---------- KEYPAD CONFIGURATION ----------
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1', '2', '3', 'A'},
  {'4', '5', '6', 'B'},
  {'7', '8', '9', 'C'},
  {'*', '0', '#', 'D'}
};

byte rowPins[ROWS] = {33, 25, 26, 27};
byte colPins[COLS] = {14, 12, 13, 32};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------- SERVO ----------
Servo servo;
#define SERVO_PIN 15

// ---------- FINGERPRINT ----------
HardwareSerial mySerial(2);
#define RX_PIN 21
#define TX_PIN 22
Adafruit_Fingerprint finger = Adafruit_Fingerprint(&mySerial);

// ---------- VIBRATION SENSOR ----------
#define VIB_PIN 19
bool vibPrevState = LOW;

// ---------- VARIABLES ----------
String inputCode = "";
String correctCode = "9289";
bool codeVerified = false;

void setup() {
  Serial.begin(115200);
  Serial.println("ESP32 - Fingerprint + Keypad + TFT + Servo + Vibration");

  // TFT init
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);
  pinMode(TFT_BL, OUTPUT);
  digitalWrite(TFT_BL, HIGH);

  displayMessage("System Ready", "Place your finger or");
  tft.setCursor(10, 40);
  tft.println("enter passcode");

  // Servo
  servo.attach(SERVO_PIN);
  servo.write(0);

  // Fingerprint
  mySerial.begin(57600, SERIAL_8N1, RX_PIN, TX_PIN);
  finger.begin(57600);
  if (finger.verifyPassword()) {
    Serial.println("Fingerprint sensor detected!");
  } else {
    Serial.println("Fingerprint sensor not found!");
    displayMessage("Error", "No Fingerprint");
    while (1);
  }

  // Vibration sensor
  pinMode(VIB_PIN, INPUT);

  delay(2000);
  displayMessage(" Place your     finger", "     or         enter       passcode");
}

void loop() {
  // ---------- VIBRATION SENSOR ----------
  int vibState = digitalRead(VIB_PIN);
  if (vibState == HIGH && vibPrevState == LOW) {
    Serial.println("Motion Detected!");
    displayMessage("Motion", "Detected!");
    delay(1500);
    displayMessage(" Place your     finger", "     or         enter       passcode");
  }
  vibPrevState = vibState;

  // ---------- KEYPAD INPUT ----------
  char key = keypad.getKey();

  if (key) {
    Serial.print("Key pressed: ");
    Serial.println(key);

    if (key == 'A') {
      enrollMode();
      displayMessage(" Place your     finger", "     or         enter       passcode");
    }
    else if (key == '#') {
      if (inputCode == correctCode) {
        codeVerified = true;
        displayMessage("Code", "Correct");
        Serial.println("Code correct!");
        openDoor();  // Open door if code correct
      } else {
        codeVerified = false;
        displayMessage("Code", "Incorrect");
      }
      inputCode = "";
      delay(1500);
      displayMessage(" Place your     finger", "     or         enter       passcode");
    }
    else if (key == '*') {
      inputCode = "";
      displayMessage("Cleared", "");
      delay(800);
      displayMessage(" Place your     finger", "     or         enter       passcode");
    }
    else {
      inputCode += key;
      updateDisplayInput(inputCode);
    }
  }

  // ---------- FINGERPRINT SCAN ----------
  int p = finger.getImage();
  if (p == FINGERPRINT_OK) {
    p = finger.image2Tz();
    if (p == FINGERPRINT_OK) {
      p = finger.fingerFastSearch();
      if (p == FINGERPRINT_OK) {
        displayMessage("Access", "Granted");
        openDoor();  // Open door if fingerprint match
        delay(1500);
        displayMessage(" Place your     finger", "     or         enter       passcode");
      } 
      else if (p == FINGERPRINT_NOTFOUND) {
        displayMessage("Access", "Denied");
        Serial.println("Fingerprint not recognized!");
        delay(1500);
        displayMessage(" Place your     finger", "     or         enter       passcode");
      }
    } else {
      displayMessage("Error", "Try Again");
      delay(1000);
      displayMessage(" Place your     finger", "     or         enter       passcode");
    }
  } else if (p != FINGERPRINT_NOFINGER) {
    displayMessage("Error", "Try Again");
    delay(1000);
    displayMessage(" Place your     finger", "     or         enter       passcode");
  }
}

// ---------- DISPLAY FUNCTIONS ----------
void displayMessage(String line1, String line2) {
  tft.fillScreen(ST77XX_BLACK);
  tft.setTextSize(2);
  tft.setTextColor(ST77XX_CYAN);
  tft.setCursor(10, 10);
  tft.println(line1);
  tft.setTextColor(ST77XX_YELLOW);
  tft.setCursor(10, 40);
  tft.println(line2);
}

void updateDisplayInput(String input) {
  tft.fillRect(0, 60, tft.width(), 40, ST77XX_BLACK);
  tft.setCursor(10, 60);
  tft.setTextSize(3);
  tft.setTextColor(ST77XX_GREEN);
  tft.print(input);
}

// ---------- ENROLL MODE ----------
void enrollMode() {
  displayMessage("Enroll Mode", "Enter ID#");

  String idStr = "";
  while (true) {
    char k = keypad.getKey();
    if (k >= '0' && k <= '9') {
      idStr += k;
      updateDisplayInput(idStr);
    } else if (k == '#') {
      break;
    }
  }

  int id = idStr.toInt();
  if (id <= 0 || id > 100) {  // limit to 100 fingerprints
    displayMessage("Invalid ID", "Use 1-100");
    delay(1500);
    return;
  }

  enrollFingerprint(id);
}

// ---------- ENROLL FINGERPRINT ----------
void enrollFingerprint(int id) {
  int p = -1;
  displayMessage("Place Finger", "");

  // First scan
  while (p != FINGERPRINT_OK) {
    p = finger.getImage();
    if (p == FINGERPRINT_NOFINGER) continue;
    if (p == FINGERPRINT_OK) displayMessage("Image", "Taken");
  }

  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) { displayMessage("Error", "1st Scan"); return; }

  displayMessage("Remove Finger", "");
  delay(2000);
  while (finger.getImage() != FINGERPRINT_NOFINGER);

  displayMessage("Place Again", "");
  p = -1;
  while (p != FINGERPRINT_OK) {
    p = finger.getImage();
    if (p == FINGERPRINT_NOFINGER) continue;
  }

  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) { displayMessage("Error", "2nd Scan"); return; }

  p = finger.createModel();
  if (p == FINGERPRINT_OK) {
    displayMessage("Model", "Created");
  } else {
    displayMessage("Model", "Failed");
    return;
  }

  p = finger.storeModel(id);
  if (p == FINGERPRINT_OK) {
    displayMessage("Enroll Done", "ID " + String(id));
  } else {
    displayMessage("Store Failed", "");
  }

  delay(2000);
}

// ---------- SERVO MOVEMENT ----------
void openDoor() {
  for (int angle = 0; angle <= 180; angle += 5) {
    servo.write(angle);
    delay(15);
  }
  delay(2000);
  for (int angle = 180; angle >= 0; angle -= 5) {
    servo.write(angle);
    delay(15);
  }
}
